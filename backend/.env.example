# Backend Configuration
DEBUG=false
ENABLE_PUBLIC_REGISTRATION=false
SECRET_KEY=please_replace_with_a_random_secret
DATABASE_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/product_knowledge
REDIS_URL=redis://localhost:6379/0
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI runtime limits
AI_REQUEST_TIMEOUT_SECONDS=30
AI_REQUEST_QUEUE_TIMEOUT_SECONDS=8
AI_MAX_CONCURRENT_REQUESTS=10

# Default Admin Account (auto-created on first startup)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=please_change_default_admin_password

# dmxapi.cn Configuration
DMXAPI_BASE_URL=https://www.dmxapi.cn
DMXAPI_API_KEY=please_fill_your_dmxapi_key

# Optional: if you want the frontend to call a fixed backend URL instead of using the Vite proxy,
# create frontend/.env and set VITE_API_BASE_URL=http://127.0.0.1:8000/api
UPLOAD_DIR=uploads
